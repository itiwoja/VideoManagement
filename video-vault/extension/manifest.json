{
  "manifest_version": 3,
  "name": "Video Vault Saver",
  "version": "0.1.0",
  "description": "右クリックメニューやワンクリックで Video Vault に動画リンクを保存する",
  "permissions": [
    "contextMenus",
    "scripting",
    "activeTab",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "http://127.0.0.1:3001/*",
    "http://localhost:3001/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Vault に保存",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "commands": {
    "save_current_tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+V",
        "mac": "Command+Shift+V"
      },
      "description": "現在のタブを Vault に保存"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
