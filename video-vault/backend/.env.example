# Video Vault backend environment variables.
# 本番では `.env` を作って設定する。`.env` 自体は gitignore 済み。

# 必須: 起動時にバリデーション。未設定なら起動失敗。
# 生成例: openssl rand -base64 64
JWT_SECRET=

# 任意: bcrypt のコストファクタ (10〜14)。既定 12。
# BCRYPT_COST=12

# 任意: Cookie の Secure flag を強制。本番 (HTTPS 配信) では必ず true。
# COOKIE_SECURE=true

# 任意: バインドアドレス。LAN/Tailscale から見せたいなら 0.0.0.0、ローカル限定なら 127.0.0.1。
# HOST=0.0.0.0

# 任意: ポート。
# PORT=3001

# 任意: CORS / CSRF の許可 Origin (カンマ区切り)。
# デフォルトは 127.0.0.1:5173 / localhost:5173 / :3001 のみ許可。
# Tailscale Funnel 等で外部公開する場合は、その Origin をここに追加する。
# 例: ALLOWED_ORIGINS=https://foo.tailxxxx.ts.net
# ALLOWED_ORIGINS=
