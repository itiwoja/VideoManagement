                if (window.player) {
                    window.player.pause()
                }
            })

            window.addEventListener('blur', () => {
                if (window.player) {
                    window.player.pause()
                }
            })

            window.addEventListener('resize', () => {
                setHlsDefaultLevel()
            })

            window.addEventListener('orientationchange', () => {
                setHlsDefaultLevel()
            })
        })
    </script>
