            <div
    x-cloak
    x-show="showPanel === 'playlist'"
    x-init="$nextTick(() => {
        $watch('showPanel', value => {
            if (value === 'playlist' && ! loading.playlist) {
                loading.playlist = true

                window.axios.get('https://missav.ws/api/playlists/mide-488-uncensored-leak').then(response => {
                    playlists = response.data.data

                    loading.playlist = false
                })
            }
        })
    })"
    x-data="{
        loading: {
            playlist: false,
        },
        playlists: [],
        togglePlaylist(key) {
            const data = {
                dvdId: 'mide-488-uncensored-leak',
                key: key,
            }

            if (event.target.checked) {
                window.axios.post('https://missav.ws/api/playlists/add', data)
            } else {
                window.axios.post('https://missav.ws/api/playlists/remove', data)
            }
        },
    }"
    class="mb-5 p-3 pb-1 sm:p-6 sm:pb-4 bg-gray-800 rounded-lg"
>
